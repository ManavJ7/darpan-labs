# Study Design Engine — frontend env template (Next.js)
# NEXT_PUBLIC_* vars are baked into the client bundle at build time. On Railway,
# they must be set BEFORE the first deploy of sde-frontend.

NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Dev-login button is SHOWN by default (backend enforces environment gate —
# /dev-login 404s unless ENVIRONMENT=development). Optionally hide the button
# in prod by setting this to "true" at frontend build time.
# NEXT_PUBLIC_HIDE_DEV_LOGIN=true
