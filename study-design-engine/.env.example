# Study Design Engine — backend env template
# Copy to .env for local dev; set each var as a Railway service variable in prod.

# --- Database & broker ---
DATABASE_URL=postgresql+asyncpg://manavrsjain@localhost:5432/darpan
REDIS_URL=redis://localhost:6379/0

# --- LLM providers ---
LLM_DEFAULT_MODEL=gpt-5.4
LLM_DEFAULT_TEMPERATURE=0.3
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- App runtime ---
ENVIRONMENT=development        # "production" in Railway
DEBUG=true                     # false in prod
IMAGE_STORAGE_PATH=./storage/images

# --- Auth ---
# Google OAuth Web Client ID (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
# Run `openssl rand -hex 32` to generate for prod.
JWT_SECRET_KEY=darpan-sde-dev-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72

# Comma-separated list of emails allowed to sign in. Empty = allow all (dev default).
# In prod, set this to the invite-only beta list.
ALLOWED_EMAILS=

# Comma-separated list of frontend origins allowed by CORS.
# Include the dev server + every prod domain serving the frontend.
CORS_ORIGINS=http://localhost:3099,http://localhost:3001,http://localhost:3000
