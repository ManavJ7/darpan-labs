      "options": [
        {"label": "Repurchase the exact same product", "value": "repurchase_same"},
        {"label": "Browse online for options before buying", "value": "browse_online"},
        {"label": "Visit a store and decide there", "value": "store_decide"},
        {"label": "Ask family or friends what they use", "value": "ask_others"},
        {"label": "Wait for a deal or discount before buying", "value": "wait_deal"}
